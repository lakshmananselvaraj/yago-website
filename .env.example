APP_NAME="Vipasa Yoga"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata
APP_KEY=change-this-to-a-random-32-char-string

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=vipasa_yoga
DB_USER=root
DB_PASS=

SESSION_NAME=vipasa_session
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

MAIL_DRIVER=log
MAIL_FROM_ADDRESS=no-reply@vipasa.demo
MAIL_FROM_NAME="Vipasa Yoga"
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

SMS_DRIVER=log

# Payment gateway. PAYMENT_MODE is informational only (shows a "Test Mode" badge
# on checkout) — whether payments actually run in test or live mode is determined
# entirely by which keys (test or live) you paste below. PAYMENT_GATEWAY picks
# which provider is active; Razorpay and Stripe are otherwise interchangeable —
# switching gateways, or switching test -> live keys, never requires a code change.
PAYMENT_MODE=test
PAYMENT_GATEWAY=razorpay

# Razorpay — leave blank to keep payment creation stubbed/non-functional until you add real keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe — optional alternate gateway (set PAYMENT_GATEWAY=stripe to activate). Leave
# blank to keep it stubbed/non-functional until you add real keys.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Sign-In — create an OAuth 2.0 Client ID (Web application) in Google Cloud Console,
# add GOOGLE_REDIRECT_URI as an authorized redirect URI there. Leave blank to keep the
# "Sign in with Google" button wired but non-functional until you add real credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_DECAY=60
RATE_LIMIT_PASSWORD_RESET_MAX=5
RATE_LIMIT_PASSWORD_RESET_DECAY=60
